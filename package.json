{
  "name": "ttc-tracker",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "seed": "pnpm db:seed",
    "db:migrate": "pnpm --filter @ttc/api prisma:migrate",
    "db:seed": "pnpm --filter @ttc/api db:seed",
    "smoke:gtfs": "pnpm --filter @ttc/api exec tsx ../../scripts/smoke/gtfs-smoke.ts",
    "smoke:corridors": "pnpm --filter @ttc/api exec tsx ../../scripts/smoke/map-corridor-smoke.ts",
    "integration:ca-realtime": "pnpm --filter @ttc/api exec tsx ../../scripts/integration/build-ca-realtime-map.ts",
    "integration:transit-heat": "pnpm --filter @ttc/api exec tsx ../../scripts/integration/build-transit-heat-tiles.ts",
    "db:clear": "pnpm --filter @ttc/api exec prisma migrate reset --schema ../../prisma/schema.prisma --force --skip-seed",
    "db:reset": "pnpm --filter @ttc/api exec prisma migrate reset --schema ../../prisma/schema.prisma --force"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  },
  "devDependencies": {
    "prisma": "^6.19.2"
  }
}
